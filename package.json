{
  "name": "rangefind",
  "version": "0.1.0",
  "description": "Range-packed static search for large sites with no search server.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "rangefind": "./bin/rangefind.js"
  },
  "exports": {
    ".": "./src/runtime.js",
    "./browser": "./dist/runtime.browser.js",
    "./builder": "./src/builder.js",
    "./analyzer": "./src/analyzer.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "docs/",
    "scripts/",
    "examples/basic/docs.jsonl",
    "examples/basic/rangefind.config.json",
    "examples/basic/public/index.html",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:browser": "node scripts/build_browser_bundle.mjs",
    "build:example": "node bin/rangefind.js build --config examples/basic/rangefind.config.json",
    "serve:example": "node scripts/serve.mjs examples/basic/public 5178",
    "bench:quality": "npm run build:example && node scripts/bench_quality.mjs",
    "bench:performance": "npm run build:example && node scripts/bench_performance.mjs",
    "bench:directories": "node scripts/bench_directory_layouts.mjs",
    "check": "for f in bin/rangefind.js src/*.js scripts/*.mjs test/*.js dist/*.js; do [ -e \"$f\" ] && node --check \"$f\"; done",
    "test": "node --test",
    "test:smoke": "npm run build:browser && npm run build:example && node scripts/smoke.mjs",
    "test:all": "npm run build:browser && npm run check && npm test && npm run test:smoke"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
